# Google OAuth Client IDs
# Create these at console.cloud.google.com
# 1. Enable Google Drive API + Google People API
# 2. OAuth consent screen -> External -> add scopes: drive.file, openid, email, profile
# 3. Create 3 OAuth 2.0 Client IDs (Web, iOS, Android)
# 4. Copy IDs below and rename this file to .env

EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your-android-client-id.apps.googleusercontent.com

# Web OAuth Authorized redirect URI:
#   Development: http://localhost:19006
#   Expo Proxy:  https://auth.expo.io/@your-expo-username/taskidea
